# =====================================
# Projekt
# =====================================

# Nazwa projektu.
# Wykorzystywana w skryptach, logach i pliku manifest.json.
PROJECT_NAME=comzezarl

# Wersja projektu.
# Przydatna do identyfikacji backupów i zmian w konfiguracji.
PROJECT_VERSION=1.0.0

# Środowisko uruchomieniowe.
# local       -> komputer deweloperski
# production  -> Raspberry Pi
PROJECT_ENV=local

# =====================================
# Docker / MariaDB
# =====================================

# Nazwa bazy danych WordPress
MYSQL_DATABASE=comzezarl_wp

# Użytkownik bazy danych wykorzystywany przez WordPress
MYSQL_USER=comzezarl_user

# Hasło użytkownika bazy danych
MYSQL_PASSWORD=CHANGE_ME

# Hasło administratora MariaDB
MYSQL_ROOT_PASSWORD=CHANGE_ME

# =====================================
# WordPress
# =====================================

# Prefiks tabel WordPress.
# Dzięki niemu wszystkie tabele w bazie będą miały nazwę np.:
# cz_posts
# cz_users
# cz_options
WORDPRESS_TABLE_PREFIX=cz_

# Port, pod którym WordPress będzie dostępny lokalnie.
# Przykład:
# http://localhost:8080
WORDPRESS_PORT=8080

# =====================================
# Backup
# =====================================

# Liczba dni przechowywania lokalnych backupów.
# Starsze katalogi zostaną automatycznie usunięte.
BACKUP_RETENTION_DAYS=180

# Czy po wykonaniu backupu wysyłać go do chmury.
# false = tylko lokalnie
# true  = lokalnie + Google Drive (rclone)
BACKUP_REMOTE_ENABLED=false

# Nazwa zdalnego repozytorium skonfigurowanego w rclone.
# Przykład:
# gdrive
# onedrive
# s3
BACKUP_REMOTE_NAME=gdrive

# Folder na zdalnym dysku, w którym będą przechowywane backupy.
BACKUP_REMOTE_PATH=Comzezarl/backups

# Czy tworzyć plik manifest.json z informacjami o backupie.
BACKUP_CREATE_MANIFEST=true

# =====================================
# UWAGA
# =====================================

# To jest przykładowy plik konfiguracyjny.
#
# Skopiuj go do pliku:
#
# .env
#
# i uzupełnij własne hasła oraz ustawienia.
#
# Plik .env NIE powinien być wysyłany do repozytorium GitHub.